# ================== API ==================
# Base URL của ladipage-backend (bao gồm prefix /api)
NEXT_PUBLIC_API_URL=http://localhost:7002/api

# Bật MSW mock API để FE chạy độc lập khi BE chưa sẵn sàng
NEXT_PUBLIC_API_MOCKING=false

# Stripe publishable key (cho Embedded Checkout modal)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# ================== SUPABASE ==================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ-your-anon-key
# Server-side only — required for landing page CRUD, builder publish, templates admin
# Supabase Dashboard → Settings → API → service_role (never expose to client)
SUPABASE_SECRET_KEY=eyJ-your-service-role-key
# Alias accepted by some routes/scripts:
# SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key
# Direct Postgres URL for running landing migrations (pnpm db:landing-migrate)
# DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres

# ================== AUTH ==================
# legacy = POST /auth/login + captcha (cần USE_SUPABASE_AUTH=false trên BE)
# supabase = Supabase signIn + POST /auth/exchange
NEXT_PUBLIC_AUTH_MODE=legacy

NEXT_PUBLIC_SESSION_COOKIE_NAME=ladipage-session
NEXT_PUBLIC_FB_SESSION_COOKIE_NAME=ladipage-fb-session
NEXT_PUBLIC_SB_REFRESH_COOKIE_NAME=ladipage-sb-refresh

# Bật mock Facebook auth khi dev không có extension
NEXT_PUBLIC_AUTH_MOCK=false

# ================== FACEBOOK (cho /facebook-ads) ==================
NEXT_PUBLIC_FB_GRAPH_VERSION=v21.0